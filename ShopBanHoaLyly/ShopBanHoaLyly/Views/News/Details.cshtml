@model ShopBanHoaLyly.Models.TinTuc
@{
	ViewData["Title"] = Model?.TieuDe ?? "Chi tiết tin tức";
	Layout = "~/Views/Shared/_ClientLayout.cshtml";
    
    // Kiểm tra xem có đang xem từ trang admin không
    bool isAdminPreview = ViewBag.IsAdminPreview == true;
}

<!-- CSS cho hình ảnh trang chi tiết -->
<style>
    .blog-post-thumb {
        text-align: center;
        margin-bottom: 30px;
        position: relative;
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
    }
    
    .blog-post-thumb img {
        max-width: 100%;
        height: auto;
        max-height: 500px;
        object-fit: cover;
        width: 100%;
        transition: transform 0.5s ease;
    }
    
    .blog-post-thumb:hover img {
        transform: scale(1.02);
    }
    
    .blog-content {
        font-size: 1.1rem;
        line-height: 1.8;
        color: #444;
    }
    
    /* Sửa hiển thị danh sách có dấu chấm */
    .blog-content ul {
        list-style-type: disc !important;
        margin-left: 30px !important;
        margin-bottom: 20px !important;
        display: block !important;
    }
    
    .blog-content ul li {
        display: list-item !important;
        margin-bottom: 8px !important;
        list-style-type: disc !important;
        padding-left: 10px !important;
    }
    
    .blog-content ol {
        list-style-type: decimal !important;
        margin-left: 30px !important;
        padding-left: 15px !important;
        margin-bottom: 20px !important;
        display: block !important;
    }
    
    .blog-content ol li {
        display: list-item !important;
        margin-bottom: 8px !important;
        list-style-type: decimal !important;
        padding-left: 10px !important;
    }
    
    /* Thêm định dạng cho danh sách lồng nhau */
    .blog-content ul ul,
    .blog-content ol ol,
    .blog-content ul ol,
    .blog-content ol ul {
        margin-top: 8px !important;
        margin-bottom: 8px !important;
        margin-left: 20px !important;
    }
    
    .blog-content img {
        max-width: 100%;
        height: auto;
        display: block;
        margin: 25px auto;
        border-radius: 8px;
        box-shadow: 0 3px 10px rgba(0, 0, 0, 0.1);
    }
    
    .blog-post-info {
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
        margin-bottom: 25px;
        padding-bottom: 20px;
        border-bottom: 1px solid #eee;
    }
    
    .blog-post-info span {
        display: flex;
        align-items: center;
        color: #666;
        font-size: 0.95rem;
    }
    
    .blog-post-info i {
        margin-right: 8px;
        color: #E72463;
    }
    
    .section-title-2 {
        font-size: 2.5rem;
        margin-bottom: 20px;
        color: #333;
        font-weight: 600;
        position: relative;
        padding-bottom: 15px;
    }
    
    .section-title-2::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        width: 80px;
        height: 3px;
        background-color: #E72463;
    }
    
    .blog-post-category {
        position: absolute;
        top: 20px;
        left: 20px;
        background-color: #E72463;
        color: white;
        padding: 5px 15px;
        border-radius: 20px;
        font-size: 0.9rem;
        font-weight: 600;
        z-index: 2;
        box-shadow: 0 3px 10px rgba(231, 36, 99, 0.3);
    }
    
    .blog-post-wrapper {
        background-color: #fff;
        padding: 30px;
        border-radius: 10px;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
    }
    
    .blog-post-date {
        position: absolute;
        bottom: 20px;
        right: 20px;
        background-color: rgba(255, 255, 255, 0.9);
        padding: 8px 15px;
        border-radius: 20px;
        font-size: 0.9rem;
        font-weight: 600;
        color: #333;
        z-index: 2;
    }
    
    .blog-navigation {
        display: flex;
        justify-content: space-between;
        margin-top: 50px;
        padding-top: 30px;
        border-top: 1px solid #eee;
    }
    
    .blog-nav-item {
        max-width: 48%;
    }
    
    .blog-nav-item a {
        display: flex;
        align-items: center;
        color: #666;
        transition: all 0.3s ease;
    }
    
    .blog-nav-item a:hover {
        color: #E72463;
    }
    
    .blog-nav-item i {
        margin: 0 10px;
    }
    
    .blog-nav-item.prev i {
        margin-right: 15px;
    }
    
    .blog-nav-item.next {
        text-align: right;
    }
    
    .blog-nav-item.next i {
        margin-left: 15px;
    }
    
    .related-posts {
        margin-top: 60px;
    }
    
    .related-posts h3 {
        font-size: 1.8rem;
        margin-bottom: 30px;
        position: relative;
        padding-bottom: 15px;
        color: #333;
    }
    
    .related-posts h3::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        width: 60px;
        height: 3px;
        background-color: #E72463;
    }
    
    @@media (max-width: 767px) {
        .section-title-2 {
            font-size: 1.8rem;
        }
        
        .blog-content {
            font-size: 1rem;
        }
        
        .blog-post-wrapper {
            padding: 20px;
        }
    }
</style>

<!-- Blog Area Wrapper Start Here -->
<div class="blog-area-wrapper">
    <!-- Breadcrumb Area Start Here -->
    <div class="breadcrumbs-area position-relative">
        <div class="container">
            <div class="row">
                <div class="col-12 text-center">
                    <div class="breadcrumb-content position-relative section-content">
                        <h3 class="title-3">Chi tiết tin tức</h3>
                        <ul>
                            <li><a href="/">Trang chủ</a></li>
                            <li><a href="/News/Index">Tin tức</a></li>
                            <li>Chi tiết tin tức</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Breadcrumb Area End Here -->
    
    <!-- Blog Main Area Start Here -->
    <div class="blog-main-area pt-5 pb-5">
        <div class="container container-default custom-area">
            <div class="row">
                <div class="col-12 col-lg-10 mx-auto col-custom">
                    <!-- Blog Details wrapper Area Start -->
                    <div class="blog-post-details">
                        <figure class="blog-post-thumb mb-4">
                            @if (!string.IsNullOrEmpty(Model?.HinhAnhDaiDien))
                            {
                                <img src="~/images/blog/@Model.HinhAnhDaiDien" alt="@Model.TieuDe">
                            }
                            else
                            {
                                <img src="~/images/blog/blog1.jpg" alt="Hình ảnh tin tức">
                            }
                            @if (Model != null)
                            {
                                <div class="blog-post-date">
                                    <i class="fa fa-calendar"></i> @Model.NgayCapNhat.ToString("dd/MM/yyyy")
                                </div>
                            }
                        </figure>
                        <section class="blog-post-wrapper product-summery">
                            <div class="section-content">
                                <h2 class="section-title-2">@Model?.TieuDe</h2>
                                <div class="blog-post-info">
                                    <span><i class="fa fa-user"></i> Đăng bởi: @Model?.MaTaiKhoanNavigation?.HoVaTen</span>
                                </div>
                                @if (Model != null)
                                {
                                    <div class="blog-content">
                                        @Html.Raw(Model.NoiDung)
                                    </div>
                                }
                                
                                <!-- Blog Navigation -->
                                <div class="blog-navigation">
                                    <div class="blog-nav-item prev">
                                        @if (isAdminPreview)
                                        {
                                            <a href="@Url.Action("Index", "News", new { area = "Admin" })">
                                                <i class="fa fa-angle-left"></i>
                                                <span>Quay lại danh sách tin tức</span>
                                            </a>
                                        }
                                        else
                                        {
                                            <a href="@Url.Action("Index", "News")">
                                                <i class="fa fa-angle-left"></i>
                                                <span>Quay lại danh sách tin tức</span>
                                            </a>
                                        }
                                    </div>
                                    @if (!isAdminPreview)
                                    {
                                        <div class="blog-nav-item next">
                                            <a href="@Url.Action("Index", "Home")">
                                                <span>Về trang chủ</span>
                                                <i class="fa fa-angle-right"></i>
                                            </a>
                                        </div>
                                    }
                                </div>
                            </div>
                        </section>
                    </div>
                    <!-- Blog Details Wrapper Area End -->
                </div>
            </div>
        </div>
    </div>
    <!-- Blog Main Area End Here -->
</div>
<!-- Blog Area Wrapper End Here -->

<!-- Scroll to Top Start -->
<a class="scroll-to-top" href="#">
    <i class="lnr lnr-arrow-up"></i>
</a>
<!-- Scroll to Top End -->

<div class="mt-no-text"></div>
