@model ShopBanHoaLyly.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
    Layout = "~/Views/Shared/_ClientLayout.cshtml";
}

<!-- Breadcrumb Area Start Here -->
<div class="breadcrumbs-area position-relative">
    <div class="container">
        <div class="row">
            <div class="col-12 text-center">
                <div class="breadcrumb-content position-relative section-content">
                    <h3 class="title-3">Đăng nhập</h3>
                    <ul>
                        <li><a href="index.html">Trang chủ</a></li>
                        <li>Đăng nhập</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Breadcrumb Area End Here -->
<!-- Login Area Start Here -->
<div class="login-register-area mt-no-text">
    <div class="container custom-area">
        <div class="row">
            <div class="col-lg-6 offset-lg-3 col-md-8 offset-md-2 col-custom">
                <div class="login-register-wrapper">
                    <div class="section-content text-center mb-5">
                        <h2 class="title-4 mb-2">Đăng nhập</h2>
                        <p class="desc-content">Vui lòng đăng nhập bằng thông tin tài khoản bên dưới.</p>
                    </div>
                    @Html.ValidationSummary(true, "", new { @class = "text-danger text-center mb-3" })
                    <form asp-action="Login" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
                        <div class="single-input-item mb-3">
                            <input asp-for="TaiKhoan" class="form-control" placeholder="Tên đăng nhập" />
                            <span asp-validation-for="TaiKhoan" class="text-danger"></span>
                        </div>
                        <div class="single-input-item mb-3">
                            <input asp-for="MatKhau" class="form-control" placeholder="Mật khẩu" type="password" />
                            <span asp-validation-for="MatKhau" class="text-danger"></span>
                        </div>
                        <div class="single-input-item mb-3">
                            <div class="custom-control custom-checkbox">
                                <input asp-for="RememberMe" class="custom-control-input" id="rememberMe" />
                                <label class="custom-control-label" for="rememberMe">Ghi nhớ đăng nhập</label>
                            </div>
                        </div>
                        <div class="single-input-item mb-3">
                            <button class="btn flosun-button secondary-btn theme-color rounded-0 w-100">Đăng nhập</button>
                        </div>
                        
                        <div class="my-3 d-flex align-items-center">
                            <hr class="flex-grow-1" style="margin: 0px; border-bottom-color: #888;">
                            <span class="px-3">HOẶC</span>
                            <hr class="flex-grow-1" style="margin: 0px; border-bottom-color: #888;">
                        </div>
                        
                        <div class="single-input-item mb-3">
                            <a href="/Home/LoginGoogle" class="btn btn-light w-100 py-3 d-flex align-items-center justify-content-center border" style="border-radius: 4px; padding-left: 15px; padding-right: 15px;">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" width="24" height="24" style="margin-right: 10px;">
                                    <path fill="#FFC107" d="M43.611,20.083H42V20H24v8h11.303c-1.649,4.657-6.08,8-11.303,8c-6.627,0-12-5.373-12-12c0-6.627,5.373-12,12-12c3.059,0,5.842,1.154,7.961,3.039l5.657-5.657C34.046,6.053,29.268,4,24,4C12.955,4,4,12.955,4,24c0,11.045,8.955,20,20,20c11.045,0,20-8.955,20-20C44,22.659,43.862,21.35,43.611,20.083z"></path>
                                    <path fill="#FF3D00" d="M6.306,14.691l6.571,4.819C14.655,15.108,18.961,12,24,12c3.059,0,5.842,1.154,7.961,3.039l5.657-5.657C34.046,6.053,29.268,4,24,4C16.318,4,9.656,8.337,6.306,14.691z"></path>
                                    <path fill="#4CAF50" d="M24,44c5.166,0,9.86-1.977,13.409-5.192l-6.19-5.238C29.211,35.091,26.715,36,24,36c-5.202,0-9.619-3.317-11.283-7.946l-6.522,5.025C9.505,39.556,16.227,44,24,44z"></path>
                                    <path fill="#1976D2" d="M43.611,20.083H42V20H24v8h11.303c-0.792,2.237-2.231,4.166-4.087,5.571c0.001-0.001,0.002-0.001,0.003-0.002l6.19,5.238C36.971,39.205,44,34,44,24C44,22.659,43.862,21.35,43.611,20.083z"></path>
                                </svg>
                                <span>Đăng nhập với Google</span>
                            </a>
                        </div>
                        
                        <div class="single-input-item text-center">
                            Chưa có tài khoản? <a asp-controller="Home" asp-action="Register" style="font-weight:bold">Tạo tài khoản</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Login Area End Here -->
<div class="mt-no-text"></div>
