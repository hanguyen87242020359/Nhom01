@{
    ViewData["Title"] = "Về chúng tôi";
    Layout = "~/Views/Shared/_ClientLayout.cshtml";
}

<!-- Breadcrumb Area Start Here -->
<div class="breadcrumbs-area position-relative">
    <div class="container">
        <div class="row">
            <div class="col-12 text-center">
                <div class="breadcrumb-content position-relative section-content">
                    <h3 class="title-3">Về chúng tôi</h3>
                    <ul>
                        <li><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                        <li>Về chúng tôi</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Breadcrumb Area End Here -->

<!-- About Area Start Here -->
<div class="about-area mt-no-text">
    <div class="container custom-area">
        <div class="row mb-5">
            <div class="col-lg-6 col-custom">
                <div class="about-image position-relative">
                    <img src="~/images/about/about-us.jpg" alt="Cửa hàng hoa Lyly">
                </div>
            </div>
            <div class="col-lg-6 col-custom">
                <div class="about-content section-title">
                    <span class="section-title-1">Giới thiệu</span>
                    <h3 class="section-title-3 pb-0 mb-4">Cửa hàng hoa Lyly</h3>
                    <p class="mb-4">
                        Cửa hàng hoa Lyly được thành lập từ năm 2025, với mục tiêu mang đến những bó hoa tươi đẹp nhất cùng dịch vụ giao hàng chuyên nghiệp đến khách hàng.
                        Chúng tôi tự hào là địa chỉ tin cậy của nhiều khách hàng khi cần tìm kiếm những món quà ý nghĩa từ hoa tươi.
                    </p>
                    <p class="mb-4">
                        Với đội ngũ nhân viên nhiều kinh nghiệm và đam mê, Lyly không chỉ đơn thuần là nơi bán hoa mà còn là nơi hiện thực hóa những cảm xúc thông qua nghệ thuật cắm hoa. 
                        Mỗi sản phẩm từ Lyly đều được chăm chút tỉ mỉ, từ việc lựa chọn loại hoa tươi nhất đến cách bó, cắm để tạo nên tác phẩm đẹp nhất.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- About Area End Here -->

<!-- Service Area Start Here -->
<div class="service-area mt-no-text mb-no-text">
    <div class="container custom-area">
        <div class="row mb-5">
            <div class="col-12 col-custom">
                <div class="section-title text-center">
                    <h3 class="section-title-3">Dịch vụ của chúng tôi</h3>
                </div>
            </div>
        </div>
        <div class="row">
            <!-- Single Service Start -->
            <div class="col-md-6 col-lg-4 col-custom text-center mb-4">
                <div class="single-service">
                    <div class="service-icon mb-4">
                        <i class="fa fa-pagelines fa-3x" style="color: #E72463;"></i>
                    </div>
                    <div class="service-content">
                        <h4 class="title-3 mb-3">Hoa tươi hàng ngày</h4>
                        <p>Chúng tôi cam kết chỉ sử dụng hoa tươi nhất, được nhập mới mỗi ngày để đảm bảo độ tươi và thời gian sử dụng lâu dài cho khách hàng.</p>
                    </div>
                </div>
            </div>
            <!-- Single Service End -->
            <!-- Single Service Start -->
            <div class="col-md-6 col-lg-4 col-custom text-center mb-4">
                <div class="single-service">
                    <div class="service-icon mb-4">
                        <i class="fa fa-paint-brush fa-3x" style="color: #E72463;"></i>
                    </div>
                    <div class="service-content">
                        <h4 class="title-3 mb-3">Thiết kế độc đáo</h4>
                        <p>Các thiết kế hoa của Lyly luôn được cập nhật theo xu hướng mới nhất, kết hợp giữa phong cách hiện đại và truyền thống.</p>
                    </div>
                </div>
            </div>
            <!-- Single Service End -->
            <!-- Single Service Start -->
            <div class="col-md-6 col-lg-4 col-custom text-center mb-4">
                <div class="single-service">
                    <div class="service-icon mb-4">
                        <i class="fa fa-truck fa-3x" style="color: #E72463;"></i>
                    </div>
                    <div class="service-content">
                        <h4 class="title-3 mb-3">Giao hàng nhanh chóng</h4>
                        <p>Dịch vụ giao hàng của chúng tôi luôn đảm bảo đúng giờ, giữ nguyên vẻ đẹp của hoa và bảo quản tốt trong quá trình vận chuyển.</p>
                    </div>
                </div>
            </div>
            <!-- Single Service End -->
            <!-- Single Service Start -->
            <div class="col-md-6 col-lg-4 col-custom text-center mb-4">
                <div class="single-service">
                    <div class="service-icon mb-4">
                        <i class="fa fa-shopping-cart fa-3x" style="color: #E72463;"></i>
                    </div>
                    <div class="service-content">
                        <h4 class="title-3 mb-3">Đặt hàng trực tuyến</h4>
                        <p>Dễ dàng đặt hàng trên website với giao diện thân thiện và quy trình thanh toán đơn giản, bảo mật và an toàn.</p>
                    </div>
                </div>
            </div>
            <!-- Single Service End -->
            <!-- Single Service Start -->
            <div class="col-md-6 col-lg-4 col-custom text-center mb-4">
                <div class="single-service">
                    <div class="service-icon mb-4">
                        <i class="fa fa-comments fa-3x" style="color: #E72463;"></i>
                    </div>
                    <div class="service-content">
                        <h4 class="title-3 mb-3">Tư vấn chuyên nghiệp</h4>
                        <p>Tư vấn viên AI sẽ giúp bạn lựa chọn hoa phù hợp với từng dịp và ngân sách.</p>
                    </div>
                </div>
            </div>
            <!-- Single Service End -->
            <!-- Single Service Start -->
            <div class="col-md-6 col-lg-4 col-custom text-center mb-4">
                <div class="single-service">
                    <div class="service-icon mb-4">
                        <i class="fa fa-magic fa-3x" style="color: #E72463;"></i>
                    </div>
                    <div class="service-content">
                        <h4 class="title-3 mb-3">Thiết kế theo yêu cầu</h4>
                        <p>Ngoài các mẫu có sẵn, chúng tôi còn nhận thiết kế theo yêu cầu riêng của khách hàng cho các dịp đặc biệt.</p>
                    </div>
                </div>
            </div>
            <!-- Single Service End -->
        </div>
    </div>
</div>
<!-- Service Area End Here -->
<div class="mt-no-text"></div>
