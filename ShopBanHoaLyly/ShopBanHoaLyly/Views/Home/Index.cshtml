<!-- Category Tiles Start -->
@{
    var categories = ViewBag.Categories as List<ShopBanHoaLyly.Models.DanhMuc> ?? new List<ShopBanHoaLyly.Models.DanhMuc>();
    var catImages = new[] { "home1-category-1.jpg", "home1-category-2.jpg", "home1-category-3.jpg", "home1-category-4.jpg", "home1-category-5.jpg", "home1-category-6.png", "home1-category-7.png", "home1-category-8.png", "home1-category-9.png", "home1-category-10.png", "home1-category-11.png", "home1-category-12.png" };
}
<style>
    .category-circle {
        width: 120px;
        height: 120px;
        object-fit: cover;
        border-radius: 50%;
        display: block;
        margin: 0 auto 8px;
        box-shadow: 0 3px 8px rgba(0, 0, 0, 0.12);
        transition: all 0.3s ease;
    }

    .category-item {
        text-align: center;
        margin-bottom: 18px;
    }

        .category-item a:hover .category-circle {
            box-shadow: 0 8px 18px rgba(0, 0, 0, 0.18);
            transform: translateY(-4px);
        }

    .category-circle.placeholder {
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-weight: 600;
        font-size: 28px;
    }
</style>
<div class="category-section" style="padding-bottom: 4em; padding-top: 4em;">
    <div class="container">
        <div class="section-title text-center mb-30">
            <span class="section-title-1">Danh mục</span>
            <h3 class="section-title-3">Mẫu hoa mới nhất 2026</h3>
        </div>
        <div class="row justify-content-center">
            @for (int i = 0; i < categories.Count; i++)
            {
                var cat = categories[i];
                var img = catImages[i % catImages.Length];
                var imgPath = System.IO.Path.Combine(Directory.GetCurrentDirectory(), "wwwroot", "images", "category", img);
                bool hasImage = System.IO.File.Exists(imgPath);
                var title = cat.TenDanhMuc ?? "";
                var name = (cat.TenDanhMuc ?? "?").Trim();
                var initial = name.Length > 0 ? name.Substring(0, 1).ToUpper() : "?";
                var hue = Math.Abs((cat.TenDanhMuc ?? "").GetHashCode()) % 360;
                var bg = $"hsl({hue},70%,45%)";

                <div class="col-6 col-sm-4 col-md-3 col-lg-2 category-item">
                    <a asp-controller="Home" asp-action="Search" asp-route-cId="@cat.MaDanhMuc">
                        @if (hasImage)
                        {
                            <img src="~/images/category/@img" alt="@title" class="category-circle" />
                        }
                        else
                        {
                            <div class="category-circle placeholder" style="background-color:@bg">@initial</div>
                        }
                        <h5 class="mt-2">@cat.TenDanhMuc</h5>
                    </a>
                </div>
            }
        </div>
    </div>
</div>
<!-- Category Tiles End -->
<!-- Shop Collection Start Here -->
<div class="shop-collection-area gray-bg pt-no-text pb-no-text">
    <div class="container custom-area">
        <div class="row" style="margin-bottom: 70px;">
            <div class="col-md-6 col-custom">
                <div class="collection-content">
                    <div class="section-title text-left">
                        <!-- Dịch -->
                        <span class="section-title-1">Hoa cho</span>
                        <h3 class="section-title-3 pb-0">Sinh nhật & Quà tặng</h3>
                    </div>
                    <div class="desc-content">
                        <!-- Dịch đoạn mô tả mẫu -->
                        <p>Chúng tôi tuyển chọn những bó hoa đẹp nhất để giúp bạn gửi gắm yêu thương và lời chúc ý nghĩa đến người thân yêu. Mỗi thiết kế đều mang một thông điệp riêng, tinh tế và đầy cảm xúc.</p>
                    </div>
                    <!-- Dịch -->
                    <a asp-controller="Home" asp-action="Search" class="btn flosun-button secondary-btn rounded-0">Xem bộ sưu tập</a>
                </div>
            </div>
            <div class="col-md-6 col-custom">
                <!--Single Banner Area Start-->
                <div class="single-banner hover-style">
                    <div class="banner-img">
                        <a href="#">
                            <img src="~/images/collection/1-4.png" alt="">
                            <div class="overlay-1"></div>
                        </a>
                    </div>
                </div>
                <!--Single Banner Area End-->
            </div>
        </div>
        <div class="row">
            <div class="col-md-6 col-custom order-2 order-md-1">
                <!--Single Banner Area Start-->
                <div class="single-banner hover-style">
                    <div class="banner-img">
                        <a href="#">
                            <img src="~/images/collection/1-5.png" alt="">
                            <div class="overlay-1"></div>
                        </a>
                    </div>
                </div>
                <!--Single Banner Area End-->
            </div>
            <div class="col-md-6 col-custom order-1 order-md-2">
                <div class="collection-content">
                    <div class="section-title text-left">
                        <!-- Dịch -->
                        <span class="section-title-1">Hoa cho</span>
                        <h3 class="section-title-3 pb-0">Ngày cưới</h3>
                    </div>
                    <div class="desc-content">
                        <!-- Dịch đoạn mô tả mẫu -->
                        <p>Chúng tôi mang đến những thiết kế hoa cưới tinh tế và sang trọng, giúp tạo nên khoảnh khắc đáng nhớ trong lễ thành hôn. Mỗi bó hoa là một biểu tượng của tình yêu, sự gắn kết và khởi đầu trọn vẹn cho đôi lứa.</p>
                    </div>
                    <!-- Dịch -->
                    <a asp-controller="Home" asp-action="Search" class="btn flosun-button secondary-btn rounded-0">Xem bộ sưu tập</a>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Shop Collection End Here -->
<!--Product Area Start-->
<div class="product-area mt-text-3">
    <div class="container custom-area-2 overflow-hidden">
        <div class="row">
            <!--Section Title Start-->
            <div class="col-12 col-custom">
                <div class="section-title text-center mb-30">
                    <!-- Dịch -->
                    <span class="section-title-1">Xu hướng nhất</span>
                    <h3 class="section-title-3">Sản phẩm nổi bật</h3>
                </div>
            </div>
            <!--Section Title End-->
        </div>
        <div class="row product-row">
            <div class="col-12 col-custom">
                <div class="product-slider swiper-container anime-element-multi">
                    <div class="swiper-wrapper">
                        @{
                            var productPairs = Model.Select((product, index) => new { product, index })
                            .GroupBy(x => x.index / 2)
                            .Select(g => g.Select(x => x.product).ToList())
                            .ToList();
                        

                        foreach (var pair in productPairs)
                        {
                        <div class="single-item swiper-slide">
                            @foreach (var product in pair)
                            {
                                var firstImage = product.HinhAnhs.FirstOrDefault()?.DuongDan;
                                var secondImage = product.HinhAnhs.Skip(1).FirstOrDefault()?.DuongDan;

                                <div class="single-product position-relative mb-30">
                                    <div class="product-image">
                                        <a class="d-block" asp-controller="Home" asp-action="Details" asp-route-id="@product.MaSanPham">
                                            <img src="~/images/product/@firstImage" alt="@product.TenSanPham" class="product-image-1 w-100" width="285px" height="285px" />
                                            <img src="~/images/product/@secondImage" alt="@product.TenSanPham" class="product-image-2 position-absolute w-100" width="285px" height="285px" />
                                        </a>
                                        <div class="add-action d-flex flex-column position-absolute">
                                            <a href="javascript:void(0);"
                                                title="Thêm vào yêu thích"
                                                onclick="addToWishlist(@product.MaSanPham)">
                                                <i class="lnr lnr-heart" data-toggle="tooltip" data-placement="left" title="Yêu thích"></i>
                                            </a>
                                            <a href="#exampleModalCenter"
                                                data-bs-toggle="modal"
                                                data-bs-target="#exampleModalCenter"
                                                data-name="@product.TenSanPham"
                                                data-price="@product.GiaBan?.ToString("C0")"
                                                data-image="@Url.Content("~/images/product/" + (product.HinhAnhs.FirstOrDefault()?.DuongDan ?? "default.jpg"))"
                                                data-desc="@product.MoTa"
                                                data-cart="@Url.Action("AddToCart", "Cart", new { id = product.MaSanPham })"
                                                data-wishlist="@Url.Action("AddToWishlist", "Wishlist", new { id = product.MaSanPham })"
                                                data-rating="@(product.DanhGia?.Any() == true ? Math.Round((double)(product.DanhGia.Average(r => r.SoSao) ?? 0)) : 0)"
                                                data-reviews="@(product.DanhGia?.Count ?? 0)"
                                                title="Xem nhanh">
                                                <i class="lnr lnr-eye" data-toggle="tooltip" data-placement="left" title="Xem nhanh"></i>
                                            </a>
                                        </div>
                                    </div>
                                    <div class="product-content">
                                        <div class="product-title">
                                            <h4 class="title-2">
                                                <a asp-controller="Home" asp-action="Details" asp-route-id="@product.MaSanPham">@product.TenSanPham</a>
                                            </h4>
                                        </div>
                                        <div class="product-rating">
                                            @{
                                                var rating = product.DanhGia?.Any() == true 
                                                    ? Math.Round((double)(product.DanhGia.Average(r => r.SoSao) ?? 0)) 
                                                    : 0;
                                                var reviews = product.DanhGia?.Count ?? 0;
                                                
                                                for (int i = 1; i <= 5; i++)
                                                {
                                                    if (i <= rating)
                                                    {
                                            <i class="fa fa-star"></i>
                                                    }
                                                    else
                                                    {
                                            <i class="fa fa-star-o"></i>
                                                    }
                                                }
                                            }
                                            <span>(@reviews)</span>
                                        </div>
                                        <div class="price-box">
                                            <span class="regular-price">@product.GiaBan?.ToString("C0")</span>
                                        </div>
                                                <a href="javascript:void(0);" class="btn product-cart" onclick="addToCart(@product.MaSanPham)" style="  width: 100%;
                                                                                                                                                        background-color: #E72463;
                                                                                                                                                        color: white;
                                                                                                                                                        padding: 8px;
                                                                                                                                                        text-align: center;
                                                                                                                                                        display: flex;
                                                                                                                                                        justify-content: center;
                                                                                                                                                        margin-top: 10px;
                                                                                                                                                        position: absolute;
                                                                                                                                                        bottom: 0;">Thêm vào giỏ hàng</a>
                                    </div>
                                </div>
                            }
                        </div>
                        }
                        }
                    </div>
                    <!-- Slider pagination -->
                    <div class="swiper-pagination default-pagination"></div>
                </div>
            </div>
        </div>
    </div>
</div>
<!--Product Area End-->
<!-- Modal -->
<div class="modal flosun-modal fade" id="exampleModalCenter" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <button type="button" class="close close-button" data-bs-dismiss="modal" aria-label="Đóng">
                <span class="close-icon" aria-hidden="true">x</span>
            </button>
            <div class="modal-body">
                <div class="container-fluid custom-area">
                    <div class="row">
                        <div class="col-md-6 col-custom">
                            <div class="modal-product-img">
                                <img id="modalProductImage" class="w-100" src="" alt="Sản phẩm" width="400px" height="400px" />
                            </div>
                        </div>
                        <div class="col-md-6 col-custom">
                            <div class="modal-product">
                                <div class="product-content">
                                    <div class="product-title">
                                        <h4 class="title" id="modalProductName"></h4>
                                    </div>
                                    <div class="price-box">
                                        <span class="regular-price" id="modalProductPrice"></span>
                                    </div>
                                    <div class="product-rating">
                                        <i class="fa fa-star"></i>
                                        <i class="fa fa-star"></i>
                                        <i class="fa fa-star"></i>
                                        <i class="fa fa-star-o"></i>
                                        <i class="fa fa-star-o"></i>
                                        <span id="modalProductReview">1 đánh giá</span>
                                    </div>
                                    <p class="desc-content" id="modalProductDesc"></p>
                                    <div class="quantity-with-btn">
                                        <div class="quantity">
                                            <div class="cart-plus-minus">
                                                <input class="cart-plus-minus-box" value="1" type="text">
                                                <div class="dec qtybutton"><i class="fa fa-minus"></i></div>
                                                <div class="inc qtybutton"><i class="fa fa-plus"></i></div>
                                            </div>
                                        </div>
                                        <div class="add-to_btn">
                                            <a class="btn product-cart button-icon flosun-button dark-btn" id="modalAddToCart" href="javascript:void(0);" data-id="">Thêm vào giỏ hàng</a>
                                            <a class="btn flosun-button secondary-btn rounded-0"
                                               id="modalAddToWishlist"
                                               href="javascript:void(0);"
                                               data-id=""
                                               onclick="addToWishlistFromModal(this)">
                                                Thêm vào yêu thích
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

