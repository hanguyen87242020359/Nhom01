<!-- News Section Start -->
<div class="news-section pb-4" style="padding-top: 50px;">
    <div class="container">
        <div class="section-title text-center mb-30">
            <span class="section-title-1">Mới nhất</span>
            <h3 class="section-title-3" style="margin-bottom:50px !important;">Tin tức</h3>
        </div>
        @{
            var newsList = ViewBag.News as List<ShopBanHoaLyly.Models.TinTuc> ?? new List<ShopBanHoaLyly.Models.TinTuc>();
        }
        <div class="row">
            @foreach (var nt in newsList)
            {
                <div class="col-md-4 col-sm-6 mb-4">
                    <div class="single-news">
                        <a asp-controller="News" asp-action="Details" asp-route-id="@nt.MaTinTuc">
                            <img src="~/images/blog/@(nt.HinhAnhDaiDien ?? "default.jpg")" alt="@nt.TieuDe" class="img-fluid" />
                        </a>
                        <h5 class="mt-2"><a asp-controller="News" asp-action="Details" asp-route-id="@nt.MaTinTuc">@nt.TieuDe</a></h5>
                        <p class="text-muted">@nt.NgayCapNhat.ToString("dd/MM/yyyy")</p>
                        <p>@(nt.TomTat != null && nt.TomTat.Length > 150 ? nt.TomTat.Substring(0, 150) + "..." : nt.TomTat)</p>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
<!-- News Section End -->
<!--FAQ-->
<section class="FAQ mt-10 container wow animate__animated animate__fadeInUp">
    <div class="FAQ-heading">
        <h1>
            Câu hỏi thường gặp
        </h1>
        <p>Chúng tôi đã tổng hợp những câu hỏi phổ biến nhất giúp bạn hiểu rõ hơn về quyền lợi, cách sử dụng và quy trình hỗ trợ khi gặp sự cố về sản phẩm. Luôn sẵn sàng đồng hành cùng bạn 24/7, mọi lúc – mọi nơi.</p>
    </div>

    <div class="FAQ-content">
        <div class="ko-faq-accordion">
            <div class="ko-accordion-item">
                <div class="ko-accordion-item-header">Quán mở cửa vào thời gian nào?</div>
                <div class="ko-accordion-item-body">
                    <p class="ko-accordion-item-body-content">Quán mở cửa từ 7:00 sáng – 11:00 tối tất cả các ngày trong tuần.</p>
                </div>
            </div>
            <div class="ko-accordion-item">
                <div class="ko-accordion-item-header">Shop có nhận giao hoa trong ngày không?</div>
                <div class="ko-accordion-item-body">
