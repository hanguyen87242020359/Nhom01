    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script>
        // Cấu hình toastr
        toastr.options = {
            "closeButton": true,
            "debug": false,
            "newestOnTop": true,
            "progressBar": true,
            "positionClass": "toast-top-right",
            "preventDuplicates": false,
            "onclick": null,
            "showDuration": "300",
            "hideDuration": "1000",
            "timeOut": "5000",
            "extendedTimeOut": "1000",
            "showEasing": "swing",
            "hideEasing": "linear",
            "showMethod": "fadeIn",
            "hideMethod": "fadeOut"
        };
        
        // Hàm xử lý chuyển hướng khi chưa đăng nhập
        function handleAjaxAuthRedirect(xhr) {
            if (xhr.status === 401 || xhr.status === 403) {
                toastr.warning('Bạn cần đăng nhập để sử dụng chức năng này');
                setTimeout(function() {
                window.location.href = '/Home/Login';
                }, 1500);
                return true;
            }
            if (xhr.responseText && xhr.responseText.indexOf('form id="loginForm"') !== -1) {
                toastr.warning('Bạn cần đăng nhập để sử dụng chức năng này');
                setTimeout(function() {
                window.location.href = '/Home/Login';
                }, 1500);
                return true;
            }
            return false;
        }

        function addToWishlist(productId) {
            $.ajax({
                url: '@Url.Action("AddToWishlistAjax", "Wishlist")',
                type: 'POST',
                data: {
                    id: productId,
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                },
                success: function (response) {
                    if (response.success) {
                        toastr.success(response.message);
                    } else {
                        toastr.warning(response.message);
                    }
                    $('.wishlist-item_count').first().text(response.count);
                },
                error: function (xhr) {
                    if (!handleAjaxAuthRedirect(xhr)) {
                    toastr.error("Có lỗi xảy ra. Vui lòng thử lại.");
                    }
                }
            });
        }

        function removeFromWishlist(productId, btn) {
            $.ajax({
                url: '@Url.Action("RemoveFromWishlistAjax", "Wishlist")',
                type: 'POST',
                data: {
                    id: productId,
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                },
                success: function (response) {
                    if (response.success) {
                        toastr.success(response.message);
                        // Xóa dòng sản phẩm khỏi bảng nếu có truyền btn
                        if (btn) {
                            var row = $(btn).closest('tr');
                            row.remove();
                            // Nếu không còn sản phẩm nào, hiển thị dòng thông báo
                            if ($('.wishlist-table tbody tr').length === 0) {
                                $('.wishlist-table tbody').append(
                                    '<tr><td colspan="5" class="text-center text-muted py-4">Không có sản phẩm nào trong danh sách yêu thích.</td></tr>'
                                );
                            }
                        }
                    } else {
                        toastr.warning(response.message);
                    }
                    // Cập nhật số lượng wishlist trên header
                    $('.wishlist-item_count').first().text(response.count);
                },
                error: function (xhr) {
                    if (!handleAjaxAuthRedirect(xhr)) {
                        toastr.error("Có lỗi xảy ra. Vui lòng thử lại.");
                    }
                }
            });
        }

        function addToCart(productId, quantity) {
            $.ajax({
                url: '/Cart/AddToCartAjax',
                type: 'POST',
                data: {
                    id: productId,
                    quantity: quantity || 1,
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                },
                success: function (response) {
                    if (response.success) {
                        toastr.success(response.message);
                    } else {
                        toastr.warning(response.message);
                    }
                    // Cập nhật số lượng giỏ hàng trên header
                    if(typeof response.count !== 'undefined')
                        $('.minicart-btn .cart-item_count').eq(0).text(response.count);
                },
                error: function (xhr) {
                    if (!handleAjaxAuthRedirect(xhr)) {
                        toastr.error("Có lỗi xảy ra. Vui lòng thử lại.");
                    }
                }
            });
        }

        function removeFromCart(productId, btn) {
            $.ajax({
                url: '/Cart/RemoveFromCartAjax',
                type: 'POST',
                data: {
                    id: productId,
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                },
                success: function (response) {
                    if (response.success) {
                        toastr.success(response.message);
                        // Xóa dòng sản phẩm khỏi bảng nếu có truyền btn
                        if (btn) {
                            var row = $(btn).closest('tr');
                            row.remove();
                            // Nếu không còn sản phẩm nào, hiển thị dòng thông báo
                            if ($('.cart-table tbody tr').length === 0) {
                                $('.cart-table tbody').append(
                                    '<tr><td colspan="7" class="text-center text-muted py-4">Không có sản phẩm nào trong giỏ hàng.</td></tr>'
                                );
                            }
                        }
                        // Cập nhật tổng tiền
                        updateCartTotal();
                    } else {
                        toastr.warning(response.message);
                    }
                    // Cập nhật số lượng giỏ hàng trên header
                    if(typeof response.count !== 'undefined')
                        $('.minicart-btn .cart-item_count').eq(0).text(response.count);
                },
                error: function (xhr) {
                    if (!handleAjaxAuthRedirect(xhr)) {
                        toastr.error("Có lỗi xảy ra. Vui lòng thử lại.");
                    }
                }
            });
        }

        // Hàm cập nhật realtime số lượng sản phẩm giỏ hàng trên header
        function updateCartCountHeader() {
            $.get('/Cart/GetCartCount', function (data) {
                // Tìm đúng span cart-item_count cho giỏ hàng (span thứ 2, sau wishlist)
                $('.minicart-btn .wishlist-item_count').eq(0).text(data);
            });
        }
    </script>

    <script>
        // Tích chọn tất cả
        $(document).on('change', '#checkAll', function () {
            $('.chon-mua').prop('checked', this.checked);
            updateCartTotal();
        });

        // Khi tick chọn/bỏ chọn sản phẩm, cũng cập nhật tổng tiền
        $(document).on('change', '.chon-mua', function () {
            updateCartTotal();
        });

        // (QUAN TRỌNG) Đảm bảo sự kiện cập nhật số lượng giỏ hàng chỉ áp dụng cho trang giỏ hàng, không áp dụng cho modal
        // Ví dụ: chỉ áp dụng cho input nằm trong bảng giỏ hàng
        $(document).on('input change', '.cart-table .cart-plus-minus-box', function () {
            var input = this;
            var row = $(input).closest('tr');
            var productId = row.find('input.chon-mua').val();
            var qty = parseInt($(input).val()) || 1;
            if (qty < 1) qty = 1;
            $(input).val(qty);
            // Cập nhật tổng phụ dòng
            var price = parseFloat(row.find('.pro-price span').text().replace(/[^\d]/g, '')) || 0;
            var subtotal = price * qty;
            row.find('.pro-subtotal span').text(subtotal.toLocaleString('vi-VN', { style: 'currency', currency: 'VND' }));
            // Cập nhật tổng tiền
            if (typeof updateCartTotal === 'function') updateCartTotal();
            // Gửi Ajax lên server để lưu số lượng mới
            if (typeof updateCartQuantity === 'function') updateCartQuantity(productId, qty, input);
        });

        // Nếu plugin không trigger sự kiện input/change khi nhấn +/-, ta chủ động trigger lại
        $(document).on('click', '.inc.qtybutton, .dec.qtybutton', function () {
            var input = $(this).siblings('input.cart-plus-minus-box');
            setTimeout(function() {
                $(input).trigger('input');
            }, 10);
        });

        // Cập nhật tổng tiền giỏ hàng
        function updateCartTotal() {
            var total = 0;
            $('.cart-table tbody tr').each(function () {
                var checked = $(this).find('.chon-mua').is(':checked');
                if (checked) {
                    var price = parseFloat($(this).find('.pro-price span').text().replace(/[^\d]/g, '')) || 0;
                    var qty = parseInt($(this).find('.cart-plus-minus-box').val()) || 1;
                    total += price * qty;
                }
            });
            $('#tamTinh').text(total.toLocaleString('vi-VN', { style: 'currency', currency: 'VND' }));
            $('#tongCong').text(total.toLocaleString('vi-VN', { style: 'currency', currency: 'VND' }));
        }

        // Gọi cập nhật tổng tiền khi trang vừa load
        $(document).ready(function () {
            updateCartTotal();
        });

        // Hàm Ajax cập nhật số lượng lên server
            function updateCartQuantity(productId, newQuantity, inputElement) {
            $.ajax({
                url: '@Url.Action("UpdateQuantityAjax", "Cart")',
                type: 'POST',
                data: {
                    id: productId,
                    quantity: newQuantity,
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                },
                success: function (response) {
                    if (inputElement && typeof response.newQuantity !== 'undefined') {
                        $(inputElement).val(response.newQuantity);
                    }
                    if (response.success) {
                        toastr.success(response.message);
                    } else {
                        toastr.warning(response.message);
                    }
                    // Cập nhật tổng phụ dòng
                    if (inputElement && typeof response.subtotal !== 'undefined') {
                        var row = $(inputElement).closest('tr');
                        row.find('.pro-subtotal span').text(response.subtotal.toLocaleString('vi-VN', { style: 'currency', currency: 'VND' }));
                    }
                    // Cập nhật tổng tiền
                    if (typeof response.total !== 'undefined') {
                        $('#tamTinh').text(response.total.toLocaleString('vi-VN', { style: 'currency', currency: 'VND' }));
                        $('#tongCong').text(response.total.toLocaleString('vi-VN', { style: 'currency', currency: 'VND' }));
                    }
                    // Cập nhật số lượng giỏ hàng trên header (giống wishlist)
                    if(typeof response.count !== 'undefined')
                        $('.minicart-btn .cart-item_count').eq(0).text(response.count);
                },
                error: function () {
                    toastr.error("Có lỗi xảy ra. Vui lòng thử lại.");
                }
            });
        }

        // Xóa sản phẩm khỏi giỏ hàng
        $(document).on('click', '.cart-remove', function (e) {
            e.preventDefault();
            var productId = $(this).closest('tr').find('input.chon-mua').val();
            removeFromCart(productId, this);
        });
        // Xóa sản phẩm khỏi wishlist
        $(document).on('click', '.wishlist-remove', function (e) {
            e.preventDefault();
            var productId = $(this).data('id');
            removeFromWishlist(productId, this);
        });

        function extractProductIdFromUrl(url) {
            if (!url) return '';
            // Tìm id dạng id=123 hoặc /123 ở cuối
            var match = url.match(/id=(\d+)/) || url.match(/\/(\d+)(\?|$)/);
            return match ? match[1] : '';
        }

        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.add-action [data-bs-toggle="modal"]').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    // Cập nhật thông tin cơ bản
                    document.getElementById('modalProductName').textContent = btn.getAttribute('data-name');
                    document.getElementById('modalProductPrice').textContent = btn.getAttribute('data-price');
                    document.getElementById('modalProductImage').src = btn.getAttribute('data-image');
                    document.getElementById('modalProductDesc').textContent = btn.getAttribute('data-desc');
                    
                    // Lấy id sản phẩm từ data-cart
                    var cartUrl = btn.getAttribute('data-cart');
                    var productId = extractProductIdFromUrl(cartUrl);
                    document.getElementById('modalAddToCart').setAttribute('data-id', productId);
                    
                    // Lấy id sản phẩm từ data-wishlist
                    var wishlistUrl = btn.getAttribute('data-wishlist');
                    var wishlistId = extractProductIdFromUrl(wishlistUrl);
                    document.getElementById('modalAddToWishlist').setAttribute('data-id', wishlistId);
                    
                    // Reset số lượng về 1 khi mở modal
                    var qtyInput = document.querySelector('#exampleModalCenter .cart-plus-minus-box');
                    if(qtyInput) qtyInput.value = 1;
                    
                    // Lấy thông tin đánh giá từ data attributes
                    var ratingStr = btn.getAttribute('data-rating') || "0";
                    var reviewCount = btn.getAttribute('data-reviews') || "0";
                    var rating = parseInt(ratingStr);
                    
                    // Cập nhật hiển thị sao trong modal
                    var ratingContainer = document.getElementById('modalProductRating');
                    ratingContainer.innerHTML = '';
                    
                    // Thêm các ngôi sao
                    for (var i = 1; i <= 5; i++) {
                        var star = document.createElement('i');
                        star.className = i <= rating ? 'fa fa-star' : 'fa fa-star-o';
                        ratingContainer.appendChild(star);
                    }
                    
                    // Thêm số lượt đánh giá
                    var reviewSpan = document.createElement('span');
                    reviewSpan.textContent = ' (' + reviewCount + ' đánh giá)';
                    ratingContainer.appendChild(reviewSpan);
                });
            });

            // Xử lý nút thêm vào giỏ hàng trong modal
            var modalAddToCartBtn = document.getElementById('modalAddToCart');
            if (modalAddToCartBtn) {
                modalAddToCartBtn.onclick = function() {
                    var productId = this.getAttribute('data-id');
                    var quantity = parseInt(document.querySelector('#exampleModalCenter .cart-plus-minus-box').value) || 1;
                    if (!productId) {
                        toastr.error("Không xác định được sản phẩm.");
                        return false;
                    }
                    addToCart(productId, quantity);
                    return false;
                };
            }
            // Xử lý nút thêm vào yêu thích trong modal
            var modalAddToWishlistBtn = document.getElementById('modalAddToWishlist');
            if (modalAddToWishlistBtn) {
                modalAddToWishlistBtn.onclick = function() {
                    var productId = this.getAttribute('data-id');
                    if (!productId) {
                        toastr.error("Không xác định được sản phẩm.");
                        return false;
                    }
                    addToWishlist(productId);
                    return false;
                };
            }
        });

        // Thêm sản phẩm từ wishlist vào giỏ hàng
        $(document).on('click', '.add-to-cart-wishlist', function (e) {
            e.preventDefault();
            var productId = $(this).data('id');
            if (!productId) {
                toastr.error('Không xác định được sản phẩm.');
                return false;
            }
            addToCart(productId, 1);
            return false;
        });
    </script>
    
    <script>
        // Xử lý hiển thị thông báo TempData từ controller
        $(document).ready(function() {
            // Hiển thị thông báo thành công
            @if (TempData["SuccessMessage"] != null)
            {
                <text>toastr.success('@TempData["SuccessMessage"]');</text>
            }
            
            // Hiển thị thông báo cảnh báo
            @if (TempData["WarningMessage"] != null)
            {
                <text>toastr.warning('@TempData["WarningMessage"]');</text>
            }
            
            // Hiển thị thông báo lỗi
            @if (TempData["ErrorMessage"] != null)
            {
                <text>toastr.error('@TempData["ErrorMessage"]');</text>
            }
            
            // Hiển thị thông báo thông tin
            @if (TempData["InfoMessage"] != null)
            {
                <text>toastr.info('@TempData["InfoMessage"]');</text>
            }
        });
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
    
    <!-- Chat Widget -->
    <partial name="_ChatWidget" />
</body>
</html>